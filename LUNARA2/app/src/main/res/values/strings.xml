    <!-- Chat Assistant -->
    <string name="chat_welcome">Hello! I am your Lunara Health Assistant. How can I help you today?</string>
    <string name="chat_diet">A balanced diet with folic acid, iron, and calcium is vital.</string>
    <string name="chat_food">Focus on fruits, vegetables, lean proteins, and whole grains.</string>
    <string name="chat_nutrition">Good nutrition supports your baby\'s development and your health.</string>
    <string name="chat_exercise">Gentle walking and prenatal yoga are generally safe and helpful.</string>
    <string name="chat_warning">Seek help for severe pain, bleeding, or sudden swelling.</string>
    <string name="chat_danger">If you feel no movement or have a seizure, call emergency immediately.</string>
    <string name="chat_checkup">Regular checkups help monitor your baby\'s growth and your well-being.</string>
    <string name="chat_visit">Don\'t miss your scheduled ANC visits for a safe pregnancy.</string>
    <string name="chat_medicine">Only take medications prescribed by your doctor.</string>
    <string name="chat_vaccine">Ensure you receive the Tetanus and other recommended vaccines.</string>
    <string name="chat_baby">Your baby is growing and learning every day inside you.</string>
    <string name="chat_kick">Counting kicks is a great way to monitor your baby\'s activity.</string>
    <string name="chat_mental">It\'s normal to feel emotional; talk to someone you trust.</string>
    <string name="chat_depression">Postpartum depression is real and treatable. Seek support early.</string>
    <string name="chat_sleep">Try sleeping on your side with a pillow between your knees.</string>
    <string name="chat_bp">Monitoring blood pressure is crucial to prevent preeclampsia.</string>
    <string name="chat_sugar">A healthy diet helps maintain stable blood sugar levels.</string>
    <string name="chat_weight">Steady weight gain is a sign of a healthy pregnancy.</string>
    <string name="chat_labor">Learn about the stages of labor to feel more prepared.</string>
    <string name="chat_trimester">Each trimester brings unique changes and milestones.</string>
    <string name="chat_hello">Hi there! How can I assist you with your pregnancy today?</string>
    <string name="chat_thank">You\'re welcome! I\'m here whenever you need help.</string>
    <string name="chat_help">I can provide info on diet, exercise, and warning signs. Just ask!</string>
    <string name="chat_default_response">I\'m not sure about that. Please consult your doctor for medical advice.</string>

