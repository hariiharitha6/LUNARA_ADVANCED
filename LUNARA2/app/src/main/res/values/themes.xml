<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme -->
    <style name="Base.Theme.LUNARA" parent="Theme.MaterialComponents.Light.NoActionBar">
        <!-- Brand colors -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary_dark</item>
        <item name="colorOnPrimary">@color/white</item>

        <item name="colorSecondary">@color/secondary</item>
        <item name="colorSecondaryVariant">@color/secondary</item>
        <item name="colorOnSecondary">@color/white</item>

        <item name="colorAccent">@color/accent</item>

        <!-- Status Bar -->
        <item name="android:statusBarColor">@color/primary</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">false</item>

        <!-- Backgrounds -->
        <item name="android:windowBackground">@color/background</item>
        <item name="colorSurface">@color/card_bg</item>
        <item name="android:colorBackground">@color/background</item>

        <!-- Typography -->
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="android:textColorHint">@color/text_hint</item>
    </style>

    <style name="Theme.LUNARA" parent="Base.Theme.LUNARA"/>

    <!-- Custom Dialog Theme -->
    <style name="LunaraDialogTheme" parent="Theme.AppCompat.Light.Dialog.Alert">
        <item name="colorAccent">@color/accent</item>
        <item name="android:windowBackground">@android:color/transparent</item>
    </style>

    <!-- Shape appearances -->
    <style name="ShapeAppearance.Lunara.Card" parent="ShapeAppearance.MaterialComponents.MediumComponent">
        <item name="cornerSize">16dp</item>
    </style>

</resources>
