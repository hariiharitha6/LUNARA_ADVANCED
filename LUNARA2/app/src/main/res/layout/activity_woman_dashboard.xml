<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">

    <!-- ================= MAIN CONTENT ================= -->
    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:id="@+id/main_content"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <com.google.android.material.appbar.AppBarLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@android:color/transparent"
            app:elevation="0dp">

            <androidx.appcompat.widget.Toolbar
                android:id="@+id/toolbar"
                android:layout_width="match_parent"
                android:layout_height="?attr/actionBarSize"
                app:navigationIcon="@android:drawable/ic_menu_sort_by_size" />
        </com.google.android.material.appbar.AppBarLayout>

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:layout_behavior="@string/appbar_scrolling_view_behavior"
            android:background="@color/background">

            <LinearLayout
                android:orientation="vertical"
                android:padding="20dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <!-- Dashboard Header -->
                <LinearLayout
                    android:orientation="vertical"
                    android:background="@drawable/gradient_header"
                    android:padding="20dp"
                    android:layout_marginBottom="16dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:text="🌙 LUNARA"
                        android:textSize="14sp"
                        android:textColor="#BBFFFFFF"
                        android:layout_marginBottom="4dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                    <TextView
                        android:text="Maternal Care Dashboard"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_on_primary"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                </LinearLayout>

                <!-- Profile Card -->
                <LinearLayout
                    android:orientation="vertical"
                    android:background="@drawable/bg_card_elevated"
                    android:elevation="4dp"
                    android:padding="20dp"
                    android:layout_marginBottom="12dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:text="👤 Patient Profile"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/primary_dark"
                        android:layout_marginBottom="12dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                    <TextView android:id="@+id/nameText"
                        android:textSize="15sp"
                        android:textColor="@color/text_primary"
                        android:layout_marginBottom="4dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                    <TextView android:id="@+id/areaText"
                        android:textSize="14sp"
                        android:textColor="@color/text_secondary"
                        android:layout_marginBottom="4dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                    <TextView android:id="@+id/mobileText"
                        android:textSize="14sp"
                        android:textColor="@color/text_secondary"
                        android:layout_marginBottom="4dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                    <TextView android:id="@+id/weightText"
                        android:textSize="14sp"
                        android:textColor="@color/text_secondary"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                </LinearLayout>

                <!-- Pregnancy Status Card -->
                <LinearLayout
                    android:orientation="vertical"
                    android:background="@drawable/bg_card_elevated"
                    android:elevation="4dp"
                    android:padding="20dp"
                    android:layout_marginBottom="12dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:text="🤰 Pregnancy Status"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/primary_dark"
                        android:layout_marginBottom="12dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                    <TextView android:id="@+id/weekText"
                        android:textSize="15sp"
                        android:textColor="@color/text_primary"
                        android:layout_marginBottom="4dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                    <TextView android:id="@+id/trimesterText"
                        android:textSize="14sp"
                        android:textColor="@color/text_secondary"
                        android:layout_marginBottom="4dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                    <TextView android:id="@+id/dueDateText"
                        android:textSize="14sp"
                        android:textColor="@color/accent"
                        android:textStyle="bold"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                </LinearLayout>

                <!-- Health Tips Card -->
                <LinearLayout
                    android:orientation="vertical"
                    android:background="@drawable/bg_card_elevated"
                    android:elevation="4dp"
                    android:padding="20dp"
                    android:layout_marginBottom="12dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:text="💡 Health Tips"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/primary_dark"
                        android:layout_marginBottom="10dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                    <TextView android:id="@+id/tipsText"
                        android:textSize="14sp"
                        android:textColor="@color/text_primary"
                        android:lineSpacingExtra="4dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                </LinearLayout>

                <!-- Quick Actions Card -->
                <LinearLayout
                    android:orientation="vertical"
                    android:background="@drawable/bg_card_elevated"
                    android:elevation="4dp"
                    android:padding="20dp"
                    android:layout_marginBottom="16dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:text="⚡ Quick Actions"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/primary_dark"
                        android:layout_marginBottom="16dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                    <Button
                        android:id="@+id/healthBtn"
                        android:text="📊  Health Tracking"
                        android:textAllCaps="false"
                        android:backgroundTint="@color/primary"
                        android:textColor="@color/text_on_primary"
                        android:textSize="15sp"
                        android:layout_marginBottom="10dp"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"/>

                    <Button
                        android:id="@+id/babyBtn"
                        android:text="👶  Baby Development"
                        android:textAllCaps="false"
                        android:backgroundTint="@color/secondary_dark"
                        android:textColor="@color/text_on_primary"
                        android:textSize="15sp"
                        android:layout_marginBottom="10dp"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"/>

                    <Button
                        android:id="@+id/emergencyBtn"
                        android:text="🚨  Emergency"
                        android:textAllCaps="false"
                        android:backgroundTint="@color/emergency_red"
                        android:textColor="@color/text_on_primary"
                        android:textSize="15sp"
                        android:layout_marginBottom="10dp"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"/>

                    <Button
                        android:id="@+id/riskBtn"
                        android:text="⚠️  Risk Card"
                        android:textAllCaps="false"
                        android:backgroundTint="@color/warning"
                        android:textColor="@color/text_primary"
                        android:textSize="15sp"
                        android:layout_marginBottom="10dp"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"/>

                    <Button
                        android:id="@+id/alertBtn"
                        android:text="🔔  Alerts"
                        android:textAllCaps="false"
                        android:backgroundTint="@color/primary_dark"
                        android:textColor="@color/text_on_primary"
                        android:textSize="15sp"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"/>
                </LinearLayout>

                <!-- ── Next Medical Visit Card ── -->
                <LinearLayout
                    android:id="@+id/nextVisitCard"
                    android:orientation="vertical"
                    android:background="@drawable/bg_card_elevated"
                    android:elevation="4dp"
                    android:padding="20dp"
                    android:layout_marginTop="12dp"
                    android:visibility="gone"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:text="📅 Next Medical Visit"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/primary"
                        android:layout_marginBottom="12dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                    <TextView
                        android:id="@+id/nextVisitDate"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:layout_marginBottom="8dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                    <TextView
                        android:id="@+id/nextVisitCountdown"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="6dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                    <TextView
                        android:id="@+id/nextVisitStatus"
                        android:textSize="13sp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                </LinearLayout>

            </LinearLayout>
        </ScrollView>
    </androidx.coordinatorlayout.widget.CoordinatorLayout>

    <!-- ================= NAVIGATION VIEW ================= -->
    <com.google.android.material.navigation.NavigationView
        android:id="@+id/navigationView"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="@color/background"
        app:headerLayout="@layout/nav_header"
        app:menu="@menu/drawer_menu"
        app:itemIconTint="@color/primary"
        app:itemTextColor="@color/text_primary"
        app:itemShapeAppearanceOverlay="@style/ShapeAppearance.Lunara.Card"
        app:itemHorizontalPadding="16dp"/>

</androidx.drawerlayout.widget.DrawerLayout>
