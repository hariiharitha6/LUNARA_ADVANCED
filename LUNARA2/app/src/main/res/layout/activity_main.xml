<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/home_gradient">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:orientation="vertical"
            android:padding="20dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- Header -->
            <TextView
                android:text="🌙 LUNARA"
                android:textSize="14sp"
                android:textColor="#BBFFFFFF"
                android:layout_marginTop="30dp"
                android:gravity="center"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>

            <TextView
                android:text="Pregnancy Tracker"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="@color/text_on_primary"
                android:gravity="center"
                android:layout_marginBottom="24dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>

            <!-- LMP Selection Card -->
            <LinearLayout
                android:orientation="vertical"
                android:background="@drawable/glass_card"
                android:padding="24dp"
                android:elevation="6dp"
                android:layout_marginBottom="16dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:text="📅 Select Last Menstrual Period (LMP)"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:textColor="@color/primary_dark"
                    android:layout_marginBottom="12dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <DatePicker
                    android:id="@+id/datePicker"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <Button
                    android:id="@+id/calcBtn"
                    android:text="Calculate Pregnancy Status"
                    android:textAllCaps="false"
                    android:background="@drawable/rounded_pink"
                    android:textColor="@color/text_on_primary"
                    android:textSize="15sp"
                    android:layout_marginTop="16dp"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"/>

                <TextView
                    android:id="@+id/resultText"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/primary_dark"
                    android:layout_marginTop="16dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:id="@+id/babyInfo"
                    android:textSize="14sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginTop="8dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

            </LinearLayout>

            <!-- Symptoms Card -->
            <LinearLayout
                android:orientation="vertical"
                android:background="@drawable/glass_card"
                android:padding="24dp"
                android:elevation="6dp"
                android:layout_marginBottom="16dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:text="🩺 Report Symptoms"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:textColor="@color/primary_dark"
                    android:layout_marginBottom="14dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <CheckBox android:id="@+id/bleeding"
                    android:text="Bleeding"
                    android:textSize="15sp"
                    android:textColor="@color/text_primary"
                    android:paddingStart="8dp"
                    android:layout_marginBottom="6dp"/>

                <CheckBox android:id="@+id/fever"
                    android:text="Fever"
                    android:textSize="15sp"
                    android:textColor="@color/text_primary"
                    android:paddingStart="8dp"
                    android:layout_marginBottom="6dp"/>

                <CheckBox android:id="@+id/swelling"
                    android:text="Severe Swelling"
                    android:textSize="15sp"
                    android:textColor="@color/text_primary"
                    android:paddingStart="8dp"
                    android:layout_marginBottom="6dp"/>

                <CheckBox android:id="@+id/noMovement"
                    android:text="No Baby Movement"
                    android:textSize="15sp"
                    android:textColor="@color/text_primary"
                    android:paddingStart="8dp"
                    android:layout_marginBottom="12dp"/>

                <Button
                    android:id="@+id/checkRiskBtn"
                    android:text="Check Risk Level"
                    android:textAllCaps="false"
                    android:background="@drawable/rounded_orange"
                    android:textColor="@color/text_on_primary"
                    android:textSize="15sp"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"/>

                <TextView
                    android:id="@+id/riskResult"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginTop="12dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

            </LinearLayout>

            <!-- Emergency Card -->
            <LinearLayout
                android:orientation="vertical"
                android:background="@drawable/glass_card"
                android:padding="24dp"
                android:elevation="6dp"
                android:layout_marginBottom="16dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <Button
                    android:id="@+id/emergencyBtn"
                    android:text="🚨 Emergency Call"
                    android:textAllCaps="false"
                    android:textSize="16sp"
                    android:background="@drawable/rounded_red"
                    android:textColor="@color/text_on_primary"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"/>

                <TextView
                    android:text="Do not panic. Help is one tap away."
                    android:textColor="@color/danger"
                    android:textStyle="bold"
                    android:textSize="13sp"
                    android:gravity="center"
                    android:layout_marginTop="10dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:id="@+id/reminderText"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/secondary_dark"
                    android:layout_marginTop="10dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</RelativeLayout>