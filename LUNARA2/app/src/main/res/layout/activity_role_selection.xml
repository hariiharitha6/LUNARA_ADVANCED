<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:padding="28dp"
    android:gravity="center"
    android:background="@drawable/bg_hero_gradient"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Header -->
    <TextView
        android:text="🌙"
        android:textSize="48sp"
        android:layout_marginBottom="12dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <TextView
        android:text="Welcome to LUNARA"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="@color/primary_dark"
        android:layout_marginBottom="6dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <TextView
        android:text="Choose your role to continue"
        android:textSize="14sp"
        android:textColor="@color/text_secondary"
        android:layout_marginBottom="40dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <!-- Woman Role Card -->
    <LinearLayout
        android:orientation="vertical"
        android:background="@drawable/bg_card_elevated"
        android:elevation="4dp"
        android:padding="20dp"
        android:gravity="center"
        android:layout_marginBottom="16dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:text="🤰"
            android:textSize="36sp"
            android:layout_marginBottom="8dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <TextView
            android:text="Pregnant Woman"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="4dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <TextView
            android:text="Track your pregnancy &amp; health"
            android:textSize="13sp"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="12dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <Button
            android:id="@+id/womanBtn"
            android:text="🤰  Continue as Woman"
            android:textAllCaps="false"
            android:background="@drawable/btn_teal_primary"
            android:textColor="@color/text_on_primary"
            android:textSize="15sp"
            android:textStyle="bold"
            android:elevation="4dp"
            android:stateListAnimator="@null"
            android:layout_width="match_parent"
            android:layout_height="52dp"/>
    </LinearLayout>

    <!-- Admin/ASHA Role Card -->
    <LinearLayout
        android:orientation="vertical"
        android:background="@drawable/bg_card_elevated"
        android:elevation="4dp"
        android:padding="20dp"
        android:gravity="center"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:text="🏥"
            android:textSize="36sp"
            android:layout_marginBottom="8dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <TextView
            android:text="ASHA Worker"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="4dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <TextView
            android:text="Monitor &amp; manage patient care"
            android:textSize="13sp"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="12dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <Button
            android:id="@+id/adminBtn"
            android:text="🏥  Continue as ASHA Worker"
            android:textAllCaps="false"
            android:background="@drawable/btn_teal_primary"
            android:textColor="@color/text_on_primary"
            android:textSize="15sp"
            android:textStyle="bold"
            android:elevation="4dp"
            android:stateListAnimator="@null"
            android:layout_width="match_parent"
            android:layout_height="52dp"/>
    </LinearLayout>

</LinearLayout>