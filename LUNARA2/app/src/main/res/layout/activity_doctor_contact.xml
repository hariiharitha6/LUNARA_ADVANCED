<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/background"
        android:orientation="vertical">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@android:color/transparent"
            app:popupTheme="@style/ThemeOverlay.AppCompat.Light" />

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <LinearLayout
                android:orientation="vertical"
                android:padding="20dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <!-- Header -->
                <TextView
                    android:text="📞"
                    android:textSize="40sp"
                    android:gravity="center"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="8dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:text="@string/doctor_contact"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:gravity="center"
                    android:layout_marginBottom="24dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>

                <!-- Emergency Helplines Card -->
                <LinearLayout
                    android:orientation="vertical"
                    android:background="@drawable/bg_card_elevated"
                    android:elevation="4dp"
                    android:padding="20dp"
                    android:layout_marginBottom="12dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:text="@string/emergency_helplines"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/danger"
                        android:layout_marginBottom="14dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                    <Button
                        android:id="@+id/call108Btn"
                        android:text="@string/ambulance_108"
                        android:textAllCaps="false"
                        android:background="@drawable/btn_danger_state"
                        android:textColor="@color/text_on_primary"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:stateListAnimator="@null"
                        android:layout_marginBottom="8dp"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"/>

                    <Button
                        android:id="@+id/call181Btn"
                        android:text="@string/women_helpline"
                        android:textAllCaps="false"
                        android:background="@drawable/btn_danger_state"
                        android:textColor="@color/text_on_primary"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:stateListAnimator="@null"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"/>
                </LinearLayout>

                <!-- Your Doctors Section -->
                <LinearLayout
                    android:orientation="vertical"
                    android:background="@drawable/bg_card_elevated"
                    android:elevation="4dp"
                    android:padding="20dp"
                    android:layout_marginBottom="12dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:text="@string/your_doctors"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/secondary"
                        android:layout_marginBottom="12dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                    <Button
                        android:id="@+id/addDoctorBtn"
                        android:text="@string/add_doctor"
                        android:textAllCaps="false"
                        android:background="@drawable/btn_teal_primary"
                        android:textColor="@color/text_on_primary"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:stateListAnimator="@null"
                        android:layout_marginBottom="12dp"
                        android:layout_width="match_parent"
                        android:layout_height="46dp"/>

                    <TextView
                        android:id="@+id/noDoctorsText"
                        android:text="@string/no_doctors_saved"
                        android:textSize="14sp"
                        android:textColor="@color/text_secondary"
                        android:gravity="center"
                        android:padding="16dp"
                        android:visibility="visible"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"/>

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/doctorRecyclerView"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false" />
                </LinearLayout>

            </LinearLayout>
        </ScrollView>
    </LinearLayout>

    <com.google.android.material.navigation.NavigationView
        android:id="@+id/navigationView"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        app:headerLayout="@layout/nav_header"
        app:menu="@menu/drawer_menu" />

</androidx.drawerlayout.widget.DrawerLayout>
