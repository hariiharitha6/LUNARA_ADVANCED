<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:background="@color/background"
    android:fitsSystemWindows="true"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:orientation="vertical"
        android:padding="20dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Header -->
        <TextView
            android:text="📞"
            android:textSize="40sp"
            android:gravity="center"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="8dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <TextView
            android:text="@string/doctor_contact"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:gravity="center"
            android:layout_marginBottom="24dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <!-- Emergency Helplines Card -->
        <LinearLayout
            android:orientation="vertical"
            android:background="@drawable/bg_card_elevated"
            android:elevation="4dp"
            android:padding="20dp"
            android:layout_marginBottom="12dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:text="@string/emergency_helplines"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/danger"
                android:layout_marginBottom="14dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <Button
                android:id="@+id/call108Btn"
                android:text="@string/ambulance_108"
                android:textAllCaps="false"
                android:background="@drawable/btn_danger_state"
                android:textColor="@color/text_on_primary"
                android:textSize="15sp"
                android:textStyle="bold"
                android:stateListAnimator="@null"
                android:layout_marginBottom="8dp"
                android:layout_width="match_parent"
                android:layout_height="50dp"/>

            <Button
                android:id="@+id/call181Btn"
                android:text="@string/women_helpline"
                android:textAllCaps="false"
                android:background="@drawable/btn_danger_state"
                android:textColor="@color/text_on_primary"
                android:textSize="15sp"
                android:textStyle="bold"
                android:stateListAnimator="@null"
                android:layout_width="match_parent"
                android:layout_height="50dp"/>
        </LinearLayout>

        <!-- Your Doctor Card -->
        <LinearLayout
            android:orientation="vertical"
            android:background="@drawable/bg_card_elevated"
            android:elevation="4dp"
            android:padding="20dp"
            android:layout_marginBottom="12dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:text="@string/your_doctor"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/secondary"
                android:layout_marginBottom="10dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:id="@+id/doctorNameText"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="4dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:id="@+id/doctorPhoneText"
                android:textSize="14sp"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="14dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <LinearLayout
                android:orientation="horizontal"
                android:layout_marginBottom="10dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <Button
                    android:id="@+id/callDoctorBtn"
                    android:text="@string/call"
                    android:textAllCaps="false"
                    android:background="@drawable/btn_teal_primary"
                    android:textColor="@color/text_on_primary"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:stateListAnimator="@null"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:layout_width="0dp"
                    android:layout_height="46dp"/>

                <Button
                    android:id="@+id/whatsappDoctorBtn"
                    android:text="@string/whatsapp"
                    android:textAllCaps="false"
                    android:background="@drawable/btn_teal_primary"
                    android:textColor="@color/text_on_primary"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:stateListAnimator="@null"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:layout_width="0dp"
                    android:layout_height="46dp"/>
            </LinearLayout>

            <Button
                android:id="@+id/saveDoctorBtn"
                android:text="@string/save_doctor"
                android:textAllCaps="false"
                android:background="@drawable/bg_input_field"
                android:textColor="@color/secondary"
                android:textSize="14sp"
                android:textStyle="bold"
                android:stateListAnimator="@null"
                android:layout_width="match_parent"
                android:layout_height="46dp"/>
        </LinearLayout>

    </LinearLayout>
</ScrollView>
