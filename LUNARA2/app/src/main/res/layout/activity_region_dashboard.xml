<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="@color/background"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Header -->
    <TextView
        android:text="🗺️ Region Risk Overview"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="@color/primary_dark"
        android:layout_marginBottom="6dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <TextView
        android:text="Regional risk heat map"
        android:textSize="14sp"
        android:textColor="@color/text_secondary"
        android:layout_marginBottom="24dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <!-- Region Cards -->
    <LinearLayout
        android:orientation="vertical"
        android:background="@drawable/bg_card_elevated"
        android:elevation="4dp"
        android:padding="16dp"
        android:layout_marginBottom="12dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <Button
            android:id="@+id/region1"
            android:text="🔴  Region A — HIGH RISK"
            android:textAllCaps="false"
            android:textSize="15sp"
            android:backgroundTint="@color/danger"
            android:textColor="@color/text_on_primary"
            android:layout_width="match_parent"
            android:layout_height="56dp"/>
    </LinearLayout>

    <LinearLayout
        android:orientation="vertical"
        android:background="@drawable/bg_card_elevated"
        android:elevation="4dp"
        android:padding="16dp"
        android:layout_marginBottom="12dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <Button
            android:id="@+id/region2"
            android:text="🟠  Region B — MODERATE"
            android:textAllCaps="false"
            android:textSize="15sp"
            android:backgroundTint="@color/warning"
            android:textColor="@color/text_primary"
            android:layout_width="match_parent"
            android:layout_height="56dp"/>
    </LinearLayout>

    <LinearLayout
        android:orientation="vertical"
        android:background="@drawable/bg_card_elevated"
        android:elevation="4dp"
        android:padding="16dp"
        android:layout_marginBottom="12dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <Button
            android:id="@+id/region3"
            android:text="🟢  Region C — LOW"
            android:textAllCaps="false"
            android:textSize="15sp"
            android:backgroundTint="@color/success"
            android:textColor="@color/text_on_primary"
            android:layout_width="match_parent"
            android:layout_height="56dp"/>
    </LinearLayout>

</LinearLayout>